# Copy this file to `.env` and fill in your key to enable Claude topic extraction.
#   cp .env.example .env
# Then paste your key below and restart the backend. The app auto-detects it.

ANTHROPIC_API_KEY=sk-ant-...

# Optional: use a cheaper/faster model (default is claude-opus-4-8).
# ANTHROPIC_MODEL=claude-haiku-4-5
